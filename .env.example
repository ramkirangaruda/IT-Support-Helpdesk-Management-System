DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5433/ticketzilla
REDIS_URL=redis://localhost:6379

# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=

LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Internal URL the NestJS API uses to reach the AI microservice
# In Docker: http://ai-service:8001  |  In local dev: http://localhost:8001
AI_SERVICE_URL=http://localhost:8001

FRONTEND_URL=http://localhost:5173

# ── OIDC (production SSO) ──────────────────────────────────────────────────────
# Leave blank in dev (dev-login is used instead). All four must be set together.
# OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_CALLBACK_URL=https://your-domain.com/api/auth/oidc/callback
